{
  "name": "iron-doctrine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Original browser-based real-time strategy game.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:biome": "biome lint .",
    "check:biome": "biome lint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
